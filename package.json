{
  "name": "float-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "float-app": "./dist/float-app"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/float-app",
    "test": "bun test",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.93",
    "effect": "^4.0.0-beta.93"
  },
  "devDependencies": {
    "@effect/language-service": "^0.87.0",
    "@types/bun": "^1.3.13",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": ["@effect/language-service"]
}
